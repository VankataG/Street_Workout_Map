@page
@model RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<section class="auth-page" aria-labelledby="register-title">
    <div class="auth-card">
        <header class="auth-header">
            <p class="auth-eyebrow">Присъедини се към SW-MAP</p>
            <h1 id="register-title">Създай профил</h1>
            <p>Регистрирай се, за да добавяш нови площадки и да редактираш своите.</p>
        </header>

        <form id="registerForm"
              asp-route-returnUrl="@Model.ReturnUrl"
              method="post"
              class="auth-form">
            <div asp-validation-summary="ModelOnly"
                 class="auth-validation-summary"
                 role="alert"></div>

            <div class="auth-field">
                <label asp-for="Input.Email">Имейл</label>
                <input asp-for="Input.Email"
                       class="form-control"
                       autocomplete="username"
                       inputmode="email"
                       aria-required="true"
                       placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="auth-validation-message"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Password">Парола</label>
                <input asp-for="Input.Password"
                       class="form-control"
                       autocomplete="new-password"
                       aria-required="true"
                       placeholder="Минимум 6 символа" />
                <span asp-validation-for="Input.Password" class="auth-validation-message"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.ConfirmPassword">Потвърди паролата</label>
                <input asp-for="Input.ConfirmPassword"
                       class="form-control"
                       autocomplete="new-password"
                       aria-required="true"
                       placeholder="Въведи паролата отново" />
                <span asp-validation-for="Input.ConfirmPassword" class="auth-validation-message"></span>
            </div>

            <button id="registerSubmit"
                    type="submit"
                    class="auth-primary-button">
                Създай профил
            </button>
        </form>

        <div class="auth-divider" aria-hidden="true">
            <span>или продължи с</span>
        </div>

        <div class="auth-social-grid">
            <button type="button"
                    class="auth-social-button"
                    aria-disabled="true"
                    title="Регистрацията с Google ще бъде добавена скоро">
                <svg class="auth-social-icon"
                     viewBox="0 0 24 24"
                     aria-hidden="true"
                     focusable="false">
                    <path fill="#4285F4" d="M21.6 12.23c0-.71-.06-1.4-.18-2.07H12v3.92h5.38a4.6 4.6 0 0 1-2 3.02v2.54h3.24c1.9-1.75 2.98-4.33 2.98-7.41Z" />
                    <path fill="#34A853" d="M12 22c2.7 0 4.97-.9 6.62-2.36l-3.24-2.54c-.9.6-2.05.96-3.38.96-2.6 0-4.8-1.76-5.59-4.12H3.07v2.62A10 10 0 0 0 12 22Z" />
                    <path fill="#FBBC05" d="M6.41 13.94A6.02 6.02 0 0 1 6.1 12c0-.67.11-1.32.31-1.94V7.44H3.07A10 10 0 0 0 2 12c0 1.62.39 3.15 1.07 4.56l3.34-2.62Z" />
                    <path fill="#EA4335" d="M12 5.94c1.47 0 2.79.5 3.83 1.5l2.87-2.87A9.63 9.63 0 0 0 12 2a10 10 0 0 0-8.93 5.44l3.34 2.62C7.2 7.7 9.4 5.94 12 5.94Z" />
                </svg>
                <span>Google</span>
            </button>

            <button type="button"
                    class="auth-social-button"
                    aria-disabled="true"
                    title="Регистрацията с Facebook ще бъде добавена скоро">
                <svg class="auth-social-icon"
                     viewBox="0 0 24 24"
                     aria-hidden="true"
                     focusable="false">
                    <path fill="#1877F2" d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.23.2 2.23.2v2.45h-1.26c-1.24 0-1.62.77-1.62 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z" />
                </svg>
                <span>Facebook</span>
            </button>
        </div>

        <p class="auth-coming-soon">
            Социалната регистрация ще бъде достъпна скоро.
        </p>

        <footer class="auth-footer">
            <span>Вече имаш профил?</span>
            <a asp-page="./Login"
               asp-route-returnUrl="@Model.ReturnUrl"
               class="auth-link auth-link-strong">
                Влез
            </a>
        </footer>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
